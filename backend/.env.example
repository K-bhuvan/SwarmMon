# SwarmMon backend — copy to backend/.env for field deployments

# Database (SQLite default; use Postgres URL in production if needed)
# SWARMMON_DATABASE_URL=sqlite:///./swarmmon.db

# Resend (free tier: https://resend.com — 100 emails/day)
# Create API key at https://resend.com/api-keys
SWARMMON_RESEND_API_KEY=re_xxxxxxxx
# Free testing without custom domain:
SWARMMON_RESEND_FROM_EMAIL=SwarmMon <onboarding@resend.dev>
# Production: verify your domain in Resend, then use e.g. alerts@yourdomain.com

# Optional: require key on POST /api/v1/events/batch and /api/v1/fleet/ingest
# SWARMMON_INGEST_API_KEY=change-me-long-random-string

# Auto-register robots from fleet ingest snapshots (default true)
# SWARMMON_AUTO_REGISTER_FIELD_ROBOTS=true

# Field fleets publish ~every 30s on ROS — use a wider live window than ros2_live.
# SWARMMON_FIELD_FLEET_LIVE_MAX_AGE_SECONDS=45

# Alert worker poll interval (seconds)
# SWARMMON_ALERT_POLL_SECONDS=60
